---
import { siteConfig } from "../config";
---

<section
  id="hero"
  class="relative overflow-hidden"
  style={`background-color: ${siteConfig.colors.surfaceLight}`}
>
  <!-- Thin top navy bar (editorial masthead feel) -->
  <div class="w-full h-[3px]" style={`background-color: ${siteConfig.colors.primaryDark}`}></div>

  <!-- Top meta strip (masthead) -->
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12 py-4 flex items-center justify-between text-[10px] md:text-xs tracking-[0.25em] uppercase" style={`color: ${siteConfig.colors.primaryDark}; font-family: 'Montserrat', sans-serif;`}>
    <span class="font-semibold">Portfolio · 2026</span>
    <span class="hidden md:block">Fort Lauderdale · Florida</span>
    <span class="font-semibold">OOW Unlimited</span>
  </div>

  <div class="w-full h-px" style={`background-color: ${siteConfig.colors.primary}30`}></div>

  <div class="max-w-[1400px] mx-auto px-6 lg:px-12 py-12 md:py-20 lg:py-24">
    <!-- Editorial split: text 5/12 | photo 7/12 -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">
      <!-- Text column -->
      <div class="lg:col-span-5 order-2 lg:order-1">
        <!-- Pre-title kicker -->
        <div class="hero-cta flex items-center gap-3 mb-6">
          <span class="w-10 h-px" style={`background-color: ${siteConfig.colors.accent}`}></span>
          <span class="text-[11px] tracking-[0.3em] uppercase font-semibold" style={`color: ${siteConfig.colors.accent}; font-family: 'Montserrat', sans-serif;`}>
            {siteConfig.title}
          </span>
        </div>

        <!-- Display title (serif) -->
        <h1
          class="hero-title text-5xl md:text-6xl lg:text-7xl xl:text-[5.5rem] font-light leading-[0.95] tracking-tight mb-6"
          style={`color: ${siteConfig.colors.primaryDark}; font-family: 'Cormorant Garamond', serif;`}
        >
          Jesus<br />
          <em class="italic font-normal" style={`color: ${siteConfig.colors.primary}`}>Alfaro</em>
        </h1>

        <!-- Tagline -->
        <p
          class="hero-subtitle text-base md:text-lg leading-relaxed mb-8 max-w-lg"
          style={`color: ${siteConfig.colors.primaryDark}; font-family: 'Montserrat', sans-serif;`}
        >
          {siteConfig.tagline}
        </p>

        <!-- Location / status line -->
        <div class="hero-description flex flex-wrap items-center gap-3 mb-10 text-sm" style={`color: ${siteConfig.colors.primary};`}>
          <span class="inline-flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" style={`color: ${siteConfig.colors.accent}`}>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <span class="font-medium tracking-wide">{siteConfig.locationLine}</span>
          </span>
        </div>

        <!-- CTAs -->
        <div class="hero-cta flex flex-col sm:flex-row gap-3 mb-10">
          <a
            href={siteConfig.cvFile}
            download
            class="btn-hover inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-full font-semibold text-sm tracking-wide uppercase shadow-lg"
            style={`background-color: ${siteConfig.colors.primaryDark}; color: ${siteConfig.colors.surfaceLight};`}
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
            Download CV
          </a>
          <a
            href="#references"
            class="btn-hover inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-full font-semibold text-sm tracking-wide uppercase border-2"
            style={`border-color: ${siteConfig.colors.primaryDark}; color: ${siteConfig.colors.primaryDark};`}
          >
            View References
          </a>
        </div>

        <!-- Stats bar -->
        <div class="hero-stats grid grid-cols-3 gap-4 pt-8 border-t" style={`border-color: ${siteConfig.colors.primary}30;`}>
          {siteConfig.stats.map((stat) => (
            <div>
              <div
                class="text-2xl md:text-3xl font-light leading-none"
                style={`color: ${siteConfig.colors.primaryDark}; font-family: 'Cormorant Garamond', serif;`}
              >{stat.value}</div>
              <div class="text-[10px] md:text-xs mt-2 tracking-[0.2em] uppercase font-medium" style={`color: ${siteConfig.colors.primary};`}>{stat.label}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Photo column — large editorial portrait -->
      <div class="lg:col-span-7 order-1 lg:order-2 hero-photo">
        <div class="relative">
          <!-- Decorative frame (teak gold hairline) -->
          <div
            class="absolute -top-3 -right-3 w-full h-full rounded-sm hidden lg:block"
            style={`border: 1px solid ${siteConfig.colors.accent}; opacity: 0.6;`}
          ></div>
          <div class="relative aspect-[4/5] lg:aspect-[3/4] overflow-hidden rounded-sm shadow-2xl">
            <img
              src="/profile.jpg"
              alt={siteConfig.name}
              class="w-full h-full object-cover"
              loading="eager"
            />
            <!-- Subtle vignette -->
            <div class="absolute inset-0 pointer-events-none" style={`background: linear-gradient(to top, ${siteConfig.colors.primaryDark}40 0%, transparent 45%);`}></div>

            <!-- Status chip overlay -->
            <div class="absolute bottom-5 left-5 right-5 flex items-center justify-between backdrop-blur-md px-4 py-3 rounded-sm" style={`background-color: ${siteConfig.colors.surfaceLight}dd; border-left: 3px solid ${siteConfig.colors.accent};`}>
              <div>
                <div class="text-[10px] tracking-[0.3em] uppercase font-semibold mb-0.5" style={`color: ${siteConfig.colors.accent};`}>Currently Aboard</div>
                <div style={`color: ${siteConfig.colors.primaryDark}; font-family: 'Cormorant Garamond', serif; font-size: 1.15rem; font-weight: 600; line-height: 1;`}>M/Y Princess Ashita — 87′</div>
              </div>
              <span class="flex h-2 w-2 relative">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full opacity-75" style={`background-color: ${siteConfig.colors.accent};`}></span>
                <span class="relative inline-flex rounded-full h-2 w-2" style={`background-color: ${siteConfig.colors.accent};`}></span>
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="w-full h-px" style={`background-color: ${siteConfig.colors.primary}30`}></div>
</section>
