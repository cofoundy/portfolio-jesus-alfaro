---
import { siteConfig } from "../config";
---

<section
  class="relative w-full overflow-hidden"
  aria-hidden="true"
>
  <div class="relative h-[55vh] md:h-[65vh] lg:h-[70vh] w-full">
    <img
      src={siteConfig.dividerImage}
      alt="Superyacht at night"
      class="absolute inset-0 w-full h-full object-cover"
      loading="lazy"
    />
    <!-- Navy overlay -->
    <div class="absolute inset-0" style={`background: linear-gradient(180deg, ${siteConfig.colors.primaryDark}60 0%, ${siteConfig.colors.primaryDark}40 50%, ${siteConfig.colors.primaryDark}80 100%);`}></div>

    <!-- Centered quote -->
    <div class="relative h-full flex items-center justify-center px-6">
      <div class="text-center max-w-3xl reveal-scale">
        <div class="flex items-center gap-3 justify-center mb-6">
          <span class="w-12 h-px" style={`background-color: ${siteConfig.colors.accent}`}></span>
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" style={`color: ${siteConfig.colors.accent};`}>
            <path d="M12 2L8 8h8l-4-6zM4 10l4 10 4-7 4 7 4-10H4z" />
          </svg>
          <span class="w-12 h-px" style={`background-color: ${siteConfig.colors.accent}`}></span>
        </div>
        <blockquote
          class="text-3xl md:text-5xl lg:text-6xl font-light italic leading-tight"
          style={`color: ${siteConfig.colors.surfaceLight}; font-family: 'Cormorant Garamond', serif;`}
        >
          {siteConfig.dividerQuote}
        </blockquote>
        <p class="mt-6 text-xs md:text-sm tracking-[0.3em] uppercase font-semibold" style={`color: ${siteConfig.colors.accent}; font-family: 'Montserrat', sans-serif;`}>
          Safety · Precision · Presentation
        </p>
      </div>
    </div>
  </div>
</section>
