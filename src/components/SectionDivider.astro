---
import { siteConfig } from "../config";

interface Props {
  image?: string;
  quote?: string;
  caption?: string;
  alt?: string;
}

const {
  image = siteConfig.dividerImage,
  quote = siteConfig.dividerQuote,
  caption = "Safety · Precision · Presentation",
  alt = "Yachting moment",
} = Astro.props;
---

<section
  class="relative w-full overflow-hidden"
  aria-hidden="true"
>
  <div class="relative h-[55vh] md:h-[65vh] lg:h-[70vh] w-full">
    <img
      src={image}
      alt={alt}
      class="absolute inset-0 w-full h-full object-cover"
      loading="lazy"
    />
    <!-- Navy overlay (vertical gradient — stronger top/bottom, mid darker than before) -->
    <div class="absolute inset-0" style={`background: linear-gradient(180deg, ${siteConfig.colors.primaryDark}B3 0%, ${siteConfig.colors.primaryDark}80 45%, ${siteConfig.colors.primaryDark}80 55%, ${siteConfig.colors.primaryDark}E0 100%);`}></div>

    <!-- Radial vignette behind text (concentrates darkness in center for legibility) -->
    <div class="absolute inset-0" style={`background: radial-gradient(ellipse at center, ${siteConfig.colors.primaryDark}99 0%, transparent 70%);`}></div>

    <!-- Centered quote -->
    <div class="relative h-full flex items-center justify-center px-6">
      <div class="text-center max-w-3xl reveal-scale">
        <div class="flex items-center gap-3 justify-center mb-6">
          <span class="w-12 h-px" style={`background-color: ${siteConfig.colors.accent}`}></span>
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" style={`color: ${siteConfig.colors.accent};`}>
            <path d="M12 2L8 8h8l-4-6zM4 10l4 10 4-7 4 7 4-10H4z" />
          </svg>
          <span class="w-12 h-px" style={`background-color: ${siteConfig.colors.accent}`}></span>
        </div>
        <blockquote
          class="text-3xl md:text-5xl lg:text-6xl font-light italic leading-tight"
          style={`color: ${siteConfig.colors.surfaceLight}; font-family: 'Cormorant Garamond', serif; text-shadow: 0 2px 24px ${siteConfig.colors.primaryDark}cc, 0 1px 4px ${siteConfig.colors.primaryDark}99;`}
        >
          {quote}
        </blockquote>
        <p class="mt-6 text-xs md:text-sm tracking-[0.3em] uppercase font-semibold" style={`color: ${siteConfig.colors.accent}; font-family: 'Montserrat', sans-serif; text-shadow: 0 1px 8px ${siteConfig.colors.primaryDark}cc;`}>
          {caption}
        </p>
      </div>
    </div>
  </div>
</section>
