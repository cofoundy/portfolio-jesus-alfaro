---
import { siteConfig } from "../config";
const entries = siteConfig.yachtingExperience;
---

<section
  id="experience"
  class="py-20 md:py-28 lg:py-32"
  style={`background-color: ${siteConfig.colors.surfaceLight}`}
>
  <div class="max-w-6xl mx-auto px-6 lg:px-12">
    <!-- Section header -->
    <div class="mb-16 md:mb-20 text-center reveal">
      <div class="flex items-center gap-3 justify-center mb-4">
        <span class="w-10 h-px" style={`background-color: ${siteConfig.colors.accent}`}></span>
        <span class="text-[11px] tracking-[0.3em] uppercase font-semibold" style={`color: ${siteConfig.colors.accent}; font-family: 'Montserrat', sans-serif;`}>
          Yachting Experience
        </span>
        <span class="w-10 h-px" style={`background-color: ${siteConfig.colors.accent}`}></span>
      </div>
      <h2
        class="text-4xl md:text-5xl lg:text-6xl font-light leading-tight"
        style={`color: ${siteConfig.colors.primaryDark}; font-family: 'Cormorant Garamond', serif;`}
      >
        Five Yachts. <em class="italic" style={`color: ${siteConfig.colors.primary}`}>One Mission.</em>
      </h2>
      <p class="mt-5 text-base md:text-lg max-w-2xl mx-auto leading-relaxed" style={`color: ${siteConfig.colors.primary}; font-family: 'Montserrat', sans-serif;`}>
        From 57′ sportfishing to 130′ motor yachts — six weeks of continuous deck operations across Fort Lauderdale, Boca Raton, and West Palm Beach.
      </p>
    </div>

    <!-- Alternating entries -->
    <div class="space-y-20 md:space-y-28">
      {entries.map((entry, idx) => {
        const imageFirst = idx % 2 === 0;
        const textColClass = imageFirst ? 'lg:order-2' : 'lg:order-1';
        const imgColClass = imageFirst ? 'lg:order-1' : 'lg:order-2';
        const revealText = imageFirst ? 'reveal-right' : 'reveal-left';
        const revealImg = imageFirst ? 'reveal-left' : 'reveal-right';
        return (
          <article class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">
            <!-- Image -->
            <div class={`lg:col-span-7 ${imgColClass} ${revealImg}`}>
              <div class="relative">
                <!-- Editorial hairline frame -->
                <div
                  class={`absolute ${imageFirst ? '-top-4 -left-4' : '-top-4 -right-4'} w-full h-full rounded-sm hidden lg:block pointer-events-none`}
                  style={`border: 1px solid ${siteConfig.colors.accent}; opacity: 0.5;`}
                ></div>
                <!-- Large photo -->
                <div class="relative aspect-[4/3] overflow-hidden rounded-sm shadow-xl">
                  <img
                    src={entry.image}
                    alt={entry.imageAlt}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                  <!-- Corner index badge -->
                  <div
                    class="absolute top-4 left-4 px-3 py-1.5 rounded-sm backdrop-blur-md text-[11px] tracking-[0.25em] font-semibold"
                    style={`background-color: ${siteConfig.colors.primaryDark}cc; color: ${siteConfig.colors.accent}; font-family: 'Montserrat', sans-serif;`}
                  >
                    № 0{idx + 1}
                  </div>
                  {entry.current && (
                    <div
                      class="absolute top-4 right-4 flex items-center gap-2 px-3 py-1.5 rounded-sm backdrop-blur-md text-[10px] tracking-[0.25em] uppercase font-semibold"
                      style={`background-color: ${siteConfig.colors.accent}; color: ${siteConfig.colors.primaryDark}; font-family: 'Montserrat', sans-serif;`}
                    >
                      <span class="flex h-1.5 w-1.5 relative">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full opacity-75" style={`background-color: ${siteConfig.colors.primaryDark};`}></span>
                        <span class="relative inline-flex rounded-full h-1.5 w-1.5" style={`background-color: ${siteConfig.colors.primaryDark};`}></span>
                      </span>
                      Current Position
                    </div>
                  )}
                </div>
              </div>
            </div>

            <!-- Text -->
            <div class={`lg:col-span-5 ${textColClass} ${revealText}`}>
              <!-- Dates chip -->
              <div class="mb-4 flex items-center gap-3">
                <span class="w-8 h-px" style={`background-color: ${siteConfig.colors.accent}`}></span>
                <span class="text-[11px] tracking-[0.25em] uppercase font-semibold" style={`color: ${siteConfig.colors.accent}; font-family: 'Montserrat', sans-serif;`}>
                  {entry.dates}
                </span>
              </div>

              <!-- Vessel name (display serif) -->
              <h3
                class="text-3xl md:text-4xl lg:text-5xl font-light leading-[1.05] mb-2"
                style={`color: ${siteConfig.colors.primaryDark}; font-family: 'Cormorant Garamond', serif;`}
              >
                {entry.vessel}
              </h3>

              <!-- Size subtitle -->
              <p class="text-sm md:text-base italic mb-1" style={`color: ${siteConfig.colors.primary}; font-family: 'Cormorant Garamond', serif; font-size: 1.15rem;`}>
                {entry.size}
              </p>

              <!-- Role & location -->
              <div class="flex flex-wrap gap-x-4 gap-y-1 mb-6 text-sm" style={`color: ${siteConfig.colors.primary};`}>
                <span class="font-medium">{entry.role}</span>
                <span style={`color: ${siteConfig.colors.accent};`}>·</span>
                <span>{entry.location}</span>
              </div>

              <!-- Bullet list -->
              <ul class="space-y-2.5 text-sm md:text-base leading-relaxed" style={`color: ${siteConfig.colors.primaryDark};`}>
                {entry.bullets.map((b) => (
                  <li class="flex items-start gap-3">
                    <span class="inline-block w-1.5 h-1.5 rounded-full mt-2 flex-shrink-0" style={`background-color: ${siteConfig.colors.accent};`}></span>
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
