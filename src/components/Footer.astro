---
import { siteConfig } from "../config";
---

<footer
  class="py-12 md:py-14 border-t"
  style={`background-color: ${siteConfig.colors.primaryDark}; border-color: ${siteConfig.colors.accent}40;`}
>
  <div class="max-w-6xl mx-auto px-6 lg:px-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 items-start mb-8">
      <!-- Brand -->
      <div>
        <div style={`color: ${siteConfig.colors.surfaceLight}; font-family: 'Cormorant Garamond', serif; font-size: 1.75rem; font-weight: 500; line-height: 1;`}>
          Jesus <em class="italic" style={`color: ${siteConfig.colors.accent};`}>Alfaro</em>
        </div>
        <p class="mt-3 text-sm leading-relaxed" style={`color: ${siteConfig.colors.surfaceLight}aa;`}>
          OOW Unlimited · Deckhand / Junior Officer<br />
          Seeking long-term yachting position.
        </p>
      </div>

      <!-- Nav -->
      <div>
        <h4 class="text-[10px] tracking-[0.3em] uppercase font-bold mb-4" style={`color: ${siteConfig.colors.accent};`}>Navigate</h4>
        <ul class="space-y-2 text-sm" style={`color: ${siteConfig.colors.surfaceLight}cc;`}>
          <li><a href="#about" class="hover:underline">Professional Profile</a></li>
          <li><a href="#experience" class="hover:underline">Yachting Experience</a></li>
          <li><a href="#certifications" class="hover:underline">Certifications</a></li>
          <li><a href="#references" class="hover:underline">References</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-[10px] tracking-[0.3em] uppercase font-bold mb-4" style={`color: ${siteConfig.colors.accent};`}>Contact</h4>
        <ul class="space-y-2 text-sm" style={`color: ${siteConfig.colors.surfaceLight}cc;`}>
          <li>
            <a href={`mailto:${siteConfig.social.email}`} class="hover:underline break-all">{siteConfig.social.email}</a>
          </li>
          <li>
            <a href={siteConfig.social.phoneUSHref} class="hover:underline">{siteConfig.social.phoneUS}</a>
          </li>
          <li>
            <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" class="hover:underline">LinkedIn →</a>
          </li>
          <li class="pt-2" style={`color: ${siteConfig.colors.surfaceLight}88;`}>Fort Lauderdale, FL</li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="pt-6 border-t flex flex-col md:flex-row items-center justify-between gap-4 text-[11px] tracking-[0.2em] uppercase" style={`border-color: ${siteConfig.colors.surfaceLight}20; color: ${siteConfig.colors.surfaceLight}66; font-family: 'Montserrat', sans-serif;`}>
      <span>© 2026 Jesus Alfaro · All Rights Reserved</span>
      <span>Available Immediately · Open to Rotational &amp; Temporary Positions</span>
    </div>
  </div>
</footer>
