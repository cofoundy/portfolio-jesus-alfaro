---
import { siteConfig } from "../config";
---

<section
  id="contact"
  class="relative py-24 md:py-32"
  style={`background-color: ${siteConfig.colors.primaryDark};`}
>
  <!-- Decorative anchor icon -->
  <svg class="absolute top-8 left-1/2 -translate-x-1/2 w-12 h-12 opacity-30" viewBox="0 0 24 24" fill="none" stroke="currentColor" style={`color: ${siteConfig.colors.accent};`}>
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m-8-8h16m-5-4a3 3 0 11-6 0 3 3 0 016 0z"></path>
  </svg>

  <div class="max-w-4xl mx-auto px-6 lg:px-12 text-center relative">
    <div class="reveal">
      <div class="flex items-center gap-3 justify-center mb-6">
        <span class="w-10 h-px" style={`background-color: ${siteConfig.colors.accent}`}></span>
        <span class="text-[11px] tracking-[0.3em] uppercase font-semibold" style={`color: ${siteConfig.colors.accent}; font-family: 'Montserrat', sans-serif;`}>
          Get in Touch
        </span>
        <span class="w-10 h-px" style={`background-color: ${siteConfig.colors.accent}`}></span>
      </div>

      <h2
        class="text-4xl md:text-5xl lg:text-6xl font-light leading-tight mb-6"
        style={`color: ${siteConfig.colors.surfaceLight}; font-family: 'Cormorant Garamond', serif;`}
      >
        {siteConfig.cta.title}
      </h2>

      <p class="text-base md:text-lg leading-relaxed max-w-2xl mx-auto mb-10" style={`color: ${siteConfig.colors.surfaceLight}cc; font-family: 'Montserrat', sans-serif;`}>
        {siteConfig.cta.description}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={`mailto:${siteConfig.social.email}?subject=${encodeURIComponent(siteConfig.cta.emailSubject)}`}
          class="btn-hover inline-flex items-center justify-center gap-2 px-8 py-4 rounded-full font-semibold text-sm tracking-wide uppercase shadow-xl"
          style={`background-color: ${siteConfig.colors.accent}; color: ${siteConfig.colors.primaryDark};`}
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
          Email — {siteConfig.social.email}
        </a>
        <a
          href={siteConfig.social.phoneUSHref}
          class="btn-hover inline-flex items-center justify-center gap-2 px-8 py-4 rounded-full font-semibold text-sm tracking-wide uppercase border-2"
          style={`border-color: ${siteConfig.colors.accent}; color: ${siteConfig.colors.accent};`}
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
          </svg>
          Call — {siteConfig.social.phoneUS}
        </a>
      </div>
    </div>
  </div>
</section>
