---
import { siteConfig } from "../config";
const oc = siteConfig.offshoreCredentials;
---

<section
  id="offshore-credentials"
  class="py-20 md:py-28"
  style={`background-color: ${siteConfig.colors.surfaceLight}`}
>
  <div class="max-w-6xl mx-auto px-6 lg:px-12">
    <!-- Header -->
    <div class="mb-14 text-center reveal">
      <div class="flex items-center gap-3 justify-center mb-4">
        <span class="w-10 h-px" style={`background-color: ${siteConfig.colors.accent}`}></span>
        <span class="text-[11px] tracking-[0.3em] uppercase font-semibold" style={`color: ${siteConfig.colors.accent}; font-family: 'Montserrat', sans-serif;`}>
          Offshore Performance Records
        </span>
        <span class="w-10 h-px" style={`background-color: ${siteConfig.colors.accent}`}></span>
      </div>
      <h2
        class="text-3xl md:text-4xl lg:text-5xl font-light leading-tight"
        style={`color: ${siteConfig.colors.primaryDark}; font-family: 'Cormorant Garamond', serif;`}
      >
        Documented by <em class="italic" style={`color: ${siteConfig.colors.primary}`}>the Captains I sailed with.</em>
      </h2>
      <p class="mt-5 text-base md:text-lg max-w-2xl mx-auto leading-relaxed" style={`color: ${siteConfig.colors.primary}; font-family: 'Montserrat', sans-serif;`}>
        {oc.summary}
      </p>
    </div>

    <!-- Captain cards (3-col, each captain quote) -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5 lg:gap-6 mb-10">
      {oc.vessels.map((v, idx) => (
        <article
          class={`reveal stagger-${idx + 1} card-hover relative p-6 lg:p-7 rounded-sm flex flex-col`}
          style={`background-color: ${siteConfig.colors.surface}; border: 1px solid ${siteConfig.colors.primary}20;`}
        >
          <!-- Flag + vessel -->
          <div class="flex items-start justify-between mb-4 pb-4 border-b" style={`border-color: ${siteConfig.colors.primary}20;`}>
            <div>
              <div class="text-[10px] tracking-[0.25em] uppercase font-semibold mb-1.5" style={`color: ${siteConfig.colors.accent}; font-family: 'Montserrat', sans-serif;`}>
                {v.period} · {v.days}
              </div>
              <h3 class="font-medium leading-tight" style={`color: ${siteConfig.colors.primaryDark}; font-family: 'Cormorant Garamond', serif; font-size: 1.5rem;`}>
                {v.vessel}
              </h3>
              <p class="text-xs mt-1 italic" style={`color: ${siteConfig.colors.primary}; font-family: 'Cormorant Garamond', serif; font-size: 0.95rem;`}>
                {v.type}
              </p>
            </div>
            <span class="text-2xl flex-shrink-0 ml-3" aria-hidden="true">{v.flag}</span>
          </div>

          <!-- Role -->
          <div class="mb-4">
            <div class="text-[10px] tracking-[0.25em] uppercase font-semibold mb-1" style={`color: ${siteConfig.colors.primary};`}>Role Onboard</div>
            <div class="text-sm font-medium" style={`color: ${siteConfig.colors.primaryDark};`}>{v.role}</div>
          </div>

          <!-- Quote -->
          <blockquote class="flex-1 mb-4 relative pl-4" style={`border-left: 2px solid ${siteConfig.colors.accent};`}>
            <p class="text-sm italic leading-relaxed" style={`color: ${siteConfig.colors.primaryDark}; font-family: 'Cormorant Garamond', serif; font-size: 1rem;`}>
              "{v.quote}"
            </p>
          </blockquote>

          <!-- Master -->
          <div class="pt-3 border-t" style={`border-color: ${siteConfig.colors.primary}15;`}>
            <div class="text-[10px] tracking-[0.25em] uppercase font-semibold mb-0.5" style={`color: ${siteConfig.colors.accent};`}>Signed by Master</div>
            <div class="text-sm font-medium" style={`color: ${siteConfig.colors.primaryDark};`}>{v.master}</div>
          </div>
        </article>
      ))}
    </div>

    <!-- Download all performances button -->
    <div class="text-center reveal">
      <a
        href={oc.documentUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-hover inline-flex items-center gap-2 px-7 py-3.5 rounded-full font-semibold text-xs tracking-[0.2em] uppercase shadow-lg"
        style={`background-color: ${siteConfig.colors.primaryDark}; color: ${siteConfig.colors.surfaceLight};`}
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
        </svg>
        Download Performance Reports & Sea Service Certificates
      </a>
      <p class="mt-4 text-xs" style={`color: ${siteConfig.colors.primary};`}>
        9 Performance Reports · 3 Sea Service Certificates · Fully signed &amp; stamped
      </p>
    </div>
  </div>
</section>
